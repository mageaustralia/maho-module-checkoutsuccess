<layout version="0.1.0">
    <!--
      Load the sortable-blocks JS + CSS on every system-config edit screen.
      The JS only activates when it finds the matching #csl-* DOM IDs, so
      loading it broadly costs ~1KB of network and zero runtime elsewhere.
    -->
    <adminhtml_system_config_edit>
        <reference name="head">
            <action method="addJs">
                <script>mageaustralia/checkoutsuccess/sortable.js</script>
            </action>
            <action method="addItem">
                <type>skin_css</type>
                <name>mageaustralia/checkoutsuccess/admin.css</name>
            </action>
        </reference>
    </adminhtml_system_config_edit>
</layout>
